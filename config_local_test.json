{
  "activation_f": "gelu",
  "device": "auto",
  "scheduler_type": "cos",
  "cosine_min_lr": 1e-8,
  "hidden_size": 256,
  "n_hidden_layers": 4,

  "n_coll": 2000,
  "n_coll_1loop": 5000,
  "n_coll_2loop": 5000,
  "eps_global": -3.0,

  "phase1_output_part": "Re",
  "n_basis": 4,
  "cy": 15.0,
  "x1_min": 20.0,
  "x1_max": 30.0,
  "x2_min": 20.0,
  "x2_max": 30.0,

  "phase2_output_part": "Both",
  "n_basis_1loop": 10,
  "cy_1loop": 5.0,
  "x1_min_1loop": 30.0, "x1_max_1loop": 40.0,
  "x2_min_1loop": 30.0, "x2_max_1loop": 40.0,
  "y1_min_1loop": 15.0, "y1_max_1loop": 20.0,

  "phase3_output_part": "Both",
  "n_basis_2loop": 22,
  "cy_2loop": 5.0,
  "x1_min_2loop": 30.0, "x1_max_2loop": 40.0,
  "x2_min_2loop": 30.0, "x2_max_2loop": 40.0,
  "y1_min_2loop": 15.0, "y1_max_2loop": 20.0,
  "y2_min_2loop": 15.0, "y2_max_2loop": 20.0,

  "coll_bc": {
    "target_total": 200,
    "n_bc_edge": 15,
    "n_corner_each": 15
  },
  "coll_bc_1loop": {
    "target_total_bc": 500,
    "n_bc_edge": 6,
    "n_face_pts": 40,
    "n_corner_extra": 5,
    "bc_abs_cap": 1e8
  },
  "coll_bc_2loop": {
    "target_total_bc": 1000,
    "n_bc_edge": 6,
    "n_face_pts": 20,
    "n_cell_pts": 30,
    "n_corner_extra": 5,
    "bc_abs_cap": 1e8
  },

  "phase1_epochs": 1000,
  "warmup_epochs_p1": 100,
  "learning_rate_p1": 1e-3,

  "phase2_epochs": 2000,
  "warmup_epochs_p2": 200,
  "learning_rate_p2": 1e-3,

  "phase3_epochs": 2000,
  "warmup_epochs_p3": 200,
  "learning_rate_p3": 1e-3,

  "enable_phase2": false,
  "enable_phase3": false,
  "use_clip_gn_phase2": true,
  "grad_clip_max_norm": 10.0,
  "use_clip_gn_phase3": true,
  "grad_clip_max_norm_phase3": 10.0,
  "run_phase3_only": false,

  "normalized_bc": true,

  "reuse_saved_models": false,
  "use_results_gpu_models": false,

  "train_two_phase_only": false,
  "run_phase2_only": false,
  "solution_scale_mode": "auto",
  "solution_scale_p1": 1e6,
  "solution_scale_p2": 1e6,
  "solution_scale_p3": 1e6,
  "solution_scale_ref_mean": 1e-1,
  "solution_scale_max": 1e12,
  "bc_loss_use_normalized": true,
  "bc_loss_scale_floor": 1e-4,
  "bc_loss_min_scale_ratio": 1.0,
  "bc_loss_abs_mse_weight": 0.05,

  "print_every": 200,
  "plot_vector_l2_hist": true,

  "postcalc_num_workers": 21,
  "postcalc_chunk_size": 2000,
  "postcalc_parallel_min_points": 5000,

  "save_phase_artifacts": true,
  "save_eval_bundle": true,
  "reuse_eval_bundle": false,

  "phase1_model_load_path": "",
  "phase1_history_load_path": "",
  "phase1_eval_bundle_load_path": "",
  "phase2_model_load_path": "",
  "phase2_history_load_path": "",
  "phase2_eval_bundle_load_path": "",
  "phase3_model_load_path": "",
  "phase3_history_load_path": "",
  "phase3_eval_bundle_load_path": "",

  "lambda1": 1.0,
  "lambda2": 1.0
}

